			</classes>
	</test> 
	
	<test name="OpenCart Registration Page Test : firefox">
		<parameter name="browser" value="edge" />
			<classes>
				<class name="com.opencart.qa.tests.RegisterPageTest" />
			</classes>
	</test> -->
	
    
